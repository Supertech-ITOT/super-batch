{
  "name": "super-batch",
  "version": "1.0.0",
  "description": "SuperBatch Desktop App - Electron + Next.js + Java Spring",
  "main": "electron/dist/main.js",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- concurrently --kill-others-on-fail \"npm run dev:next\" \"npm run dev:spring\" \"npm run dev:electron\"",
    "dev:next": "next dev -p 3000",
    "dev:spring": "dotenv -e .env -- cmd /c \"cd spring-backend && mvnw.cmd spring-boot:run\"",
    "dev:electron": "wait-on http://localhost:3000 http://localhost:8080 && tsc -p tsconfig.electron.json && electron .",
    "build": "npm run build:next && npm run build:electron",
    "build:next": "next build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package": "npm run build && electron-builder",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "date-fns": "^4.4.0",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.76.0",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "use-debounce": "^10.1.1",
    "wait-on": "^9.0.6",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "electron": "^42.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
